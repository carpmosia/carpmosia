<windows:EmotesWindow
    xmlns="https://spacestation14.io"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="Content.Client.UserInterface.Systems.Emotes.Windows.EmotesWindow"
    xmlns:windows="clr-namespace:Content.Client.UserInterface.Systems.Emotes.Windows"
    Name="EmotesList"
    HorizontalExpand="True"
    Title="{Loc ui-emotesmenu-title}"
    VerticalExpand="True"
    Resizable="True"
    MinHeight="200"
    MinWidth="250"
    SetHeight="250"
    SetWidth="450"
>
    <ScrollContainer VerticalExpand="True" HorizontalExpand="True" Margin="2">
        <GridContainer Name="EmotesGrid" Columns="3" HorizontalExpand="True"/>
    </ScrollContainer>
</windows:EmotesWindow>
