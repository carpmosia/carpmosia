<Button
    xmlns="https://spacestation14.io"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="Content.Client.UserInterface.Controls.IconButton"
    MinSize="0 24"
    Margin="1"
>
    <BoxContainer
        Orientation="Horizontal"
        MinSize="0 24"
        Margin="1"
    >
        <TextureRect
            Name="Icon"
            Access="Public"
            Stretch="Scale"
            SetSize="24 24"
            Margin="0 0 5 0"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
        />
        <RichTextLabel
            Name="Label"
            Access="Public"
            HorizontalExpand="True"
            VerticalExpand="True"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Margin="1"
            Visible="True"
        />
    </BoxContainer>
</Button>
